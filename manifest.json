{
  "manifest_version": 3,
  "name": "VisionAssist",
  "description": "Enhancing web accessibility for visually impaired users with AI-powered features",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage", "scripting", "tts"],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/tts.js", "content/content.js", "content/image-describer.js"],
      "css": [
        "content/styles/high-contrast.css",
        "content/styles/large-text.css",
        "content/styles/simplified.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
